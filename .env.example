DISCORD_TOKEN=your_discord_bot_token
# If you previously used discordtoken / DISCORDTOKEN, the bot now accepts those aliases too,
# but DISCORD_TOKEN is still the recommended name.
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_BASE_URL=https://api.openai.com/v1
OPENAI_EMBED_API_KEY=your_embedding_api_key
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_RERANK_BASE_URL=https://api.openai.com/v1
OPENAI_RERANK_API_KEY=your_rerank_api_key
OPENAI_RERANK_MODEL=
# Optional. If empty, requests rely on the outer context timeout.
# Useful for slow multimodal / emoji-analysis endpoints.
OPENAI_HTTP_TIMEOUT_SECONDS=
SYSTEM_PROMPT=你是Discord聊天助手，回答清晰、友好，避免重复。
# Main persistent storage. Runtime config, plugin registry/storage, chat memory,
# summaries, worldbook, and sqlite-vec retrieval data are stored here.
BOT_SQLITE_PATH=bot.db
# Legacy/bootstrap JSON. Super admins are still read from here, and older
# bot_config.json fields are imported into SQLite automatically on first run.
BOT_CONFIG_FILE=bot_config.json
BOT_COMMAND_GUILD_ID=
PLUGINS_DIR=plugins
